---
import "../styles/complete.css";
import Layout from "../layouts/Layout.astro";
import LocationIcon from "../assets/location.svg";
import BrandName from "../assets/brand-name.svg";
import LinkedInIcon from "../assets/linkedin.svg";
import Button from "../components/Button.astro";
---

<Layout>
	<div class="wrapper blobs flow main-wrapper">
		<section class="flow">
			<h1>
				Hi! I'm
				<BrandName class="inline-text-svg" role="img" aria-label="Ola" />
			</h1>
			<p class="text-step-2">I create <span class="font-semibold">websites</span> that are <span class="font-semibold">intuitive</span> to use and <span class="font-semibold">fun</span> to look at.</p>
		</section>
		<section class="flow stack-medium">
			<h2>I'm interested in</h2>
			<ul role="list" class="bar-list">
				<li>Front-end development</li>
				<li>Accessibility</li>
				<li>User interface design</li>
				<li>User experience</li>
			</ul>
		</section>
		<section class="flow stack-medium">
			<h2>I'm based in</h2>
			<LocationIcon class="location-icon-svg" role="img" aria-label="Eiffel Tower" />
			<p>Paris, France</p>
		</section>
		<section class="flow stack-medium">
			<h2>Find me on</h2>
			<div class="platform-link">
				<LinkedInIcon class="platform-icon-svg" role="img" aria-label="LinkedIn" />
				<a href="https://www.linkedin.com/in/ola-hn" target="_blank">
					LinkedIn
				</a>
			</div>
		</section>
		<section class="flow stack-medium">
			<h2>Email me at</h2>
			<altcha-widget
				obfuscated="VxgcTO+Lc1mi9gpqumkYnYeZEsF4p1pNisD6MtJLcU0="
				floating="auto"
			>
				<Button title="Click to reveal" />
			</altcha-widget>
		</section>
	</div>
</Layout>

<style>
	.inline-text-svg {
		height: 1.2cap;
		fill: var(--color-primary);
	}

	.location-icon-svg {
		height: 6em;
		width: 6em;
		fill: var(--color-primary);
	}

	.platform-icon-svg {
		width: 2em;
		fill: var(--color-primary);
	}
</style>

<script>
	import '@altcha/plugins/obfuscation';
	import 'altcha';
</script>
